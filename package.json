{
  "name": "lakaw",
  "version": "0.1.0",
  "description": "Tiny, dependency-free A* pathfinding library with a stable priority queue. Extracted from Amping (amping.app).",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsup src/index.ts --format cjs,esm --clean && tsc -p tsconfig.build.json",
    "build:demo": "vite build --config vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "astar",
    "a-star",
    "pathfinding",
    "pathfinder",
    "search",
    "graph",
    "priority-queue",
    "routing",
    "game-ai",
    "typescript"
  ],
  "author": "Kier Abelo <kiergabelo@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kiergabelo/lakaw"
  },
  "homepage": "https://github.com/kiergabelo/lakaw",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
